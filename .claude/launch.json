{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "careerpilot-streamlit",
      "runtimeExecutable": "venv/Scripts/streamlit.exe",
      "runtimeArgs": ["run", "app.py", "--server.headless", "true"],
      "port": 8501
    },
    {
      "name": "careerpilot-api",
      "runtimeExecutable": "venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["api:app", "--host", "127.0.0.1", "--port", "8000"],
      "port": 8000
    }
  ]
}
